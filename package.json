{
  "name": "an-inventory-backend",
  "version": "1.0.0",
  "description": "backend application for an inventory ",
  "main": "index.js",
  "scripts": {
    "test": "nodemon --exec 'mocha' 'tests/**/*.js' --watch 'controllers/**/*.js'",
    "start": "nodemon -r dotenv/config index.js",
    "migrations:generate": "sequelize-mig migration:make -n ",
    "migrations:run": "npx sequelize-cli db:migrate"
  },
  "author": "YawOtuo",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mysql2": "^3.6.1",
    "nodemon": "^3.0.1",
    "sequelize": "^6.33.0",
    "sequelize-cli": "^6.6.1",
    "sequelize-mig": "^3.1.3"
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "chai-http": "^4.4.0",
    "mocha": "^10.2.0",
    "sequelize-auto-migrations": "^1.0.3",
    "sinon": "^16.1.0"
  }
}
